# ============================================================
# 🚛 Shipment Delay Early Warning System — Environment Config
# ============================================================
# Copy this file to .env and update values for your environment.

# ── Database ─────────────────────────────────────────────────
# SQLite (default — zero install, great for local dev)
DATABASE_URL=sqlite:///./shipment_delay.db
# PostgreSQL (production — uncomment and update)
# DATABASE_URL=postgresql://user:password@localhost:5432/shipment_delay

# ── JWT Authentication ───────────────────────────────────────
JWT_SECRET_KEY=super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ── Redis (optional — falls back to in-memory cache) ─────────
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false

# ── External APIs (optional — uses mocks by default) ─────────
OPENWEATHER_API_KEY=
OPENWEATHER_ENABLED=false

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=100

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── ML Models ────────────────────────────────────────────────
DEFAULT_MODEL=xgboost
MODELS_DIR=models

# ── Data Pipeline ────────────────────────────────────────────
# Data mode: 'real' (Kaggle E-Commerce Shipping Dataset) or 'synthetic' (numpy random)
DATA_MODE=real

# ── Kaggle (for downloading real dataset) ────────────────────
# Option A: Set these env vars directly
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key
# Option B: Place kaggle.json in ~/.kaggle/ (downloaded from kaggle.com/settings)

